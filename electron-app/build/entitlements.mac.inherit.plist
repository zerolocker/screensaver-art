<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Inherited by the Electron child/helper processes (GPU, Renderer, Plugin, …).
  Same hardened-runtime relaxations as the main app plus `inherit`, which makes
  each helper inherit the parent's sandbox/runtime instead of declaring its own.
-->
<plist version="1.0">
<dict>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>
	<key>com.apple.security.inherit</key>
	<true/>
</dict>
</plist>
