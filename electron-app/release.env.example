# Copy this file to `release.env` (gitignored) and fill in your values, then run:
#   pnpm dist:mac:release
#
# These are NOT secrets — the cert name + Team ID are embedded in every signed
# app you ship, and the keychain profile is just a local label (the real Apple
# credentials live in your macOS Keychain via `notarytool store-credentials`).
# release.env is gitignored only because the values are developer-specific.

# Your "Developer ID Application" identity, exactly as shown by:
#   security find-identity -v -p codesigning
LART_CODESIGN_IDENTITY="NAME (TEAMID)"

# The notarytool keychain profile you created with:
#   xcrun notarytool store-credentials "living-art-notary" \
#     --apple-id "you@example.com" --team-id "TEAMID" --password "app-specific-password"
APPLE_KEYCHAIN_PROFILE="living-art-notary"

# --- Alternative to APPLE_KEYCHAIN_PROFILE: explicit Apple ID creds ---
# APPLE_ID="you@example.com"
# APPLE_APP_SPECIFIC_PASSWORD="abcd-efgh-ijkl-mnop"
# APPLE_TEAM_ID="TEAMID"
