{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@screensaver-art/ui": ["./src/index.ts"],
      "@screensaver-art/ui/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
