{
  "name": "@screensaver-art/electron-app",
  "version": "1.3.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "bundle-appex": "bash scripts/bundle-appex.sh",
    "dev": "pnpm bundle-appex && electron-vite dev",
    "build": "pnpm bundle-appex && electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "dist": "pnpm build && electron-builder --publish never --config electron-builder.cjs",
    "dist:mac": "pnpm build && electron-builder --mac --universal --publish never --config electron-builder.cjs",
    "dist:mac:release": "bash scripts/dist-mac-release.sh",
    "dist:win": "pnpm build && electron-builder --win --publish never --config electron-builder.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web"
  },
  "dependencies": {
    "@screensaver-art/constants": "workspace:*",
    "@screensaver-art/ui": "workspace:*",
    "@supabase/supabase-js": "^2.99.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.564.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^36.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
